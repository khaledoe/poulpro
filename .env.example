# Copier ce fichier en .env et remplir les valeurs

# URL de la base de données PostgreSQL (Railway, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/poulpro?schema=public"

# Secret JWT pour les sessions (minimum 32 caractères aléatoires)
SESSION_SECRET="votre-secret-tres-long-et-aleatoire-ici"

# URL de production (optionnel)
NEXTAUTH_URL="https://votre-app.railway.app"
